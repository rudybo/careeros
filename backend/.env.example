# CareerOS - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME=CareerOS
APP_VERSION=0.1.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./careeros.db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# File upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
